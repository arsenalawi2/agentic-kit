# Copy to .env and fill in. NEVER commit .env.
#
# DAK standard env vars. Prefix any project-specific ones with your
# project's short code, e.g. FOO_API_TOKEN.

# Admin auth — backend/auth.py require_admin dep.
DETAILED_PASSWORD=changeme

# Observability (optional)
SENTRY_DSN=

# Database — docker-compose sets its own, this is for local runs.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app
